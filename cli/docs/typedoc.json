{
  "$schema": "https://typedoc.org/schema.json",
  "name": "X-Ray 16 Types",
  "entryPoints": ["../../src/types/**/*.d.ts"],
  "entryPointStrategy": "expand",
  "out": "../../target/docs",
  "includeVersion": true,
  "hideGenerator": true,
  "disableSources": true,
  "cleanOutputDir": true,
  "searchInComments": true,
  "navigationLinks": {
    "GitHub": "https://github.com/xray-forge/xray-16-types",
    "npm": "https://www.npmjs.com/package/xray16"
  },
  "sort": ["alphabetical", "static-first", "visibility", "enum-value-ascending"]
}
