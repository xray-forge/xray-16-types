{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "esnext",
    "declaration": true,
    "outDir": "../../target/pkg/xray16/mocks",
    "rootDir": "../../src/mocks",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "xray16/alias": ["../../target/pkg/xray16/alias"]
    },
    "types": ["@typescript-to-lua/language-extensions", "lua-types/jit", "jest", "node"]
  },
  "include": ["../../src/mocks/**/*"],
  "exclude": ["../../src/mocks/**/*.test.ts"]
}
