{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../../src",
    "outDir": "../../target/pkg/xray16",
    "esModuleInterop": true,
    "types": ["@typescript-to-lua/language-extensions", "lua-types/jit", "jest", "node"]
