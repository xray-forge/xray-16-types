{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "esnext",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "../../target/tmp/lib",
    "rootDir": "../../src/lib",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["@typescript-to-lua/language-extensions"]
  },
  "include": ["../../src/lib/**/*"],
  "exclude": []
}
