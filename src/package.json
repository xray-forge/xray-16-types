{
  "name": "xray16",
  "version": "^2.0.0-experimental.7",
  "description": "TypeScript declarations, mocks, helpers, and TypeScriptToLua plugins for XRF X-Ray 16 scripts.",
  "license": "MIT",
  "author": "Neloreck",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xray-forge/stalker-xrf-xray16-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/xray-forge/stalker-xrf-xray16-sdk/issues"
  },
  "homepage": "https://xray-forge.github.io/stalker-xrf-xray16-sdk/index.html",
  "keywords": [
    "stalker",
    "xray",
    "xray16",
    "xrf",
    "typescript",
    "typescript-to-lua",
    "tstl",
    "lua",
    "modding"
  ],
  "main": "index.d.ts",
  "types": "index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "jest": "^29.0.0 || ^30.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^6.0.0",
    "typescript-to-lua": "^1.37.0"
  },
  "peerDependenciesMeta": {
    "jest": {
      "optional": true
    },
    "ts-jest": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "fengari": "^0.1.5",
    "ini": "^5.0.0"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.d.ts"
    },
    "./macros": {
      "types": "./macros.d.ts",
      "default": "./macros.js"
    },
    "./alias": {
      "types": "./alias.d.ts",
      "default": "./alias.js"
    },
    "./lib": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./mocks": {
      "types": "./mocks/index.d.ts",
      "default": "./mocks/index.js"
    },
    "./mocks/xray16-runtime": {
      "types": "./mocks/xray16-runtime.d.ts",
      "default": "./mocks/xray16-runtime.js"
    },
    "./testing": {
      "types": "./testing/index.d.ts",
      "default": "./testing/index.js"
    },
    "./testing/setup-xray-runtime": {
      "types": "./testing/setup-xray-runtime.d.ts",
      "default": "./testing/setup-xray-runtime.js"
    },
    "./testing/utils": {
      "types": "./testing/utils/index.d.ts",
      "default": "./testing/utils/index.js"
    },
    "./testing/matchers": {
      "types": "./testing/matchers/index.d.ts",
      "default": "./testing/matchers/index.js"
    },
    "./plugins/constants": {
      "types": "./plugins/constants.d.ts",
      "default": "./plugins/constants.js"
    },
    "./plugins/inline": "./plugins/inline.js",
    "./plugins/libcompile": "./plugins/libcompile.js",
    "./plugins/luabind": "./plugins/luabind.js",
    "./plugins/macros": "./plugins/macros.js",
    "./plugins/optimize": "./plugins/optimize.js",
    "./plugins/strip": "./plugins/strip.js",
    "./plugins/tracy": "./plugins/tracy.js",
    "./package.json": "./package.json",
    "./typedefs/extensions": "./typedefs/extensions.d.ts",
    "./typedefs/jest": "./typedefs/jest.d.ts",
    "./typedefs/luajit": "./typedefs/luajit.d.ts",
    "./typedefs/lfs": "./typedefs/lfs.d.ts",
    "./typedefs/marshal": "./typedefs/marshal.d.ts"
  }
}
