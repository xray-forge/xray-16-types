{
  "name": "xray16",
  "version": "2.0.0",
  "author": "Neloreck",
  "repository": "https://github.com/xray-forge/xray-16-types",
  "homepage": "https://xray-forge.github.io/xray-16-types/index.html",
  "private": false,
  "main": "index.d.ts",
  "types": "index.d.ts",
  "scripts": {
    "prepublish": "npm run build",
    "prepack": "npm run build",
    "build": "npm run build:plugins && npm run build:macros && npm run build:mocks && npm run build:alias && npm run build:types",
    "build:plugins": "rolldown -c rolldown.config.mjs && tsc src/plugins/constants.ts --declaration --emitDeclarationOnly --outDir plugins --skipLibCheck --ignoreConfig",
    "build:macros": "tsc src/macros.ts --declaration --outDir . --module commonjs --moduleResolution node --target esnext --skipLibCheck --types @typescript-to-lua/language-extensions --ignoreDeprecations 6.0 --ignoreConfig",
    "build:mocks": "tsc -p tsconfig.mocks.json",
    "build:alias": "tsc -p tsconfig.alias.json",
    "build:types": "rolldown -c rolldown.dts.config.mjs",
    "build:docs": "typedoc",
    "test": "jest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ./src/tsconfig.json && tsc --noEmit -p ./tsconfig.mocks.json",
    "typedoc": "typedoc",
    "format": "prettier --write \"**/*.(js|ts|tsx|md)\" && eslint . --fix",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "typescript-to-lua": "^1.37.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.5.14",
    "@types/node": "22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript-to-lua/language-extensions": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^63.0.7",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "lua-types": "^2.13.1",
    "prettier": "^3.4.2",
    "rolldown": "^1.1.4",
    "rolldown-plugin-dts": "^0.26.0",
    "ts-jest": "^29.4.11",
    "typedoc": "^0.28.19",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.62.0",
    "typescript-to-lua": "1.37.0"
  },
  "files": [
    "plugins/**/*",
    "typedefs/**/*",
    "mocks/**/*",
    "index.d.ts",
    "macros.js",
    "macros.d.ts",
    "alias.js",
    "alias.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.d.ts"
    },
    "./macros": {
      "types": "./macros.d.ts",
      "default": "./macros.js"
    },
    "./alias": {
      "types": "./alias.d.ts",
      "default": "./alias.js"
    },
    "./mocks": {
      "types": "./mocks/index.d.ts",
      "default": "./mocks/index.js"
    },
    "./plugins/constants": {
      "types": "./plugins/constants.d.ts",
      "default": "./plugins/constants.js"
    },
    "./plugins/inline": "./plugins/inline.js",
    "./plugins/luabind": "./plugins/luabind.js",
    "./plugins/macros": "./plugins/macros.js",
    "./plugins/optimize": "./plugins/optimize.js",
    "./plugins/strip": "./plugins/strip.js",
    "./plugins/tracy": "./plugins/tracy.js",
    "./package.json": "./package.json",
    "./typedefs/extensions": "./typedefs/extensions.d.ts",
    "./typedefs/luajit": "./typedefs/luajit.d.ts",
    "./typedefs/lfs": "./typedefs/lfs.d.ts",
    "./typedefs/marshal": "./typedefs/marshal.d.ts"
  },
  "dependencies": {
    "fengari": "^0.1.5"
  }
}
