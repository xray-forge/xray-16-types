{
  "name": "xray16",
  "version": "1.6.5",
  "author": "Neloreck",
  "repository": "https://github.com/xray-forge/xray-16-types",
  "homepage": "https://xray-forge.github.io/xray-16-types/index.html",
  "private": false,
  "main": "xray16.d.ts",
  "types": "xray16.d.ts",
  "scripts": {
    "prepublish": "npm run build",
    "prepack": "npm run build",
    "build": "npm run build:plugins && npm run build:types",
    "build:plugins": "rolldown -c rolldown.config.mjs && tsc src/plugins/constants.ts --declaration --emitDeclarationOnly --outDir plugins --skipLibCheck",
    "build:types": "rollup -c rollup.dts.config.mjs",
    "build:docs": "typedoc",
    "test": "jest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ./src/tsconfig.json",
    "typedoc": "typedoc",
    "format": "prettier --write \"**/*.(js|ts|tsx|md)\" && eslint . --fix",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "typescript-to-lua": "^1.28.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.5.14",
    "@types/node": "22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript-to-lua/language-extensions": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^63.0.7",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "rolldown": "^1.1.4",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "ts-jest": "^29.4.11",
    "typedoc": "^0.27.5",
    "typescript": "5.7.2",
    "typescript-eslint": "^8.62.0",
    "typescript-to-lua": "1.28.1"
  },
  "files": [
    "plugins/**/*",
    "xray16.d.ts",
    "README.md",
    "LICENSE"
  ]
}
