{
  "name": "xray-16-types-project",
  "version": "1.0.0",
  "author": "Neloreck",
  "repository": "https://github.com/xray-forge/xray-16-types",
  "homepage": "https://xray-forge.github.io/xray-16-types/index.html",
  "private": true,
  "scripts": {
    "clean": "rimraf ./target",
    "build": "npm run clean && npm run build:plugins && npm run build:macros && npm run build:mocks && npm run build:alias && npm run build:lib && npm run build:types && npm run build:pkg",
    "build:plugins": "rolldown -c cli/build/rolldown.config.mjs && tsc -p cli/build/tsconfig.plugins.json",
    "build:macros": "tsc -p cli/build/tsconfig.macros.json",
    "build:mocks": "tsc -p cli/build/tsconfig.mocks.json",
    "build:alias": "tsc -p cli/build/tsconfig.alias.json",
    "build:lib": "tsc -p cli/build/tsconfig.lib.json",
    "build:types": "rolldown -c cli/build/rolldown.dts.config.mjs",
    "build:pkg": "tsx cli/deploy/prepare.ts",
    "docs": "typedoc --options cli/docs/typedoc.json",
    "test": "jest --config cli/test/jest.config.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ./src/tsconfig.json && tsc --noEmit -p ./cli/build/tsconfig.mocks.json && tsc --noEmit -p ./cli/tsconfig.json",
    "format": "prettier --write \"**/*.(js|ts|tsx|md)\" && eslint . --fix",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.5.14",
    "@types/node": "22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript-to-lua/language-extensions": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^63.0.7",
    "fengari": "^0.1.5",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "lua-types": "^2.13.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.1.3",
    "rolldown": "^1.1.4",
    "rolldown-plugin-dts": "^0.26.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.62.0",
    "typescript-to-lua": "1.37.0"
  }
}
