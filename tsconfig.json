{
  "compilerOptions": {
    "target": "esnext",
    "noImplicitOverride": true,
    "lib": ["esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "types": ["node", "@typescript-to-lua/language-extensions", "lua-types/jit"]
  },
  "exclude": ["target", "cli", "src/alias.ts", "src/mocks", "src/**/*.test.ts"]
}
